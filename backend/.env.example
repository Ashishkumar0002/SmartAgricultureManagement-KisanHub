# Default local setup (works without PostgreSQL)
DATABASE_URL=sqlite:///./sams.db
# PostgreSQL example
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sams_db
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://127.0.0.1:4200,http://127.0.0.1:4201
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
